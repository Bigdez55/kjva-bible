{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CorrectionLedger",
  "type": "object",
  "required": [
    "schema_version",
    "skill_id",
    "skill_name",
    "current_version",
    "correction_history"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "skill_id": {
      "type": "string"
    },
    "skill_name": {
      "type": "string"
    },
    "current_version": {
      "type": "string"
    },
    "tier": {
      "type": "string"
    },
    "hard_constraints": {
      "type": "array"
    },
    "immutable_facts": {
      "type": "array"
    },
    "correction_history": {
      "type": "array"
    },
    "regression_test_ids": {
      "type": "array"
    },
    "last_updated": {
      "type": "string"
    }
  }
}
