{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "diagram",
  "description": "Schema for any map, diagram, or layout artifact produced by the Apex system. Every diagram kind is defined in the taxonomy below; T1 uses applies_to + mandatory to determine which diagrams to produce for a given repo.",
  "type": "object",
  "properties": {
    "id":          { "type": "string" },
    "title":       { "type": "string" },
    "kind": {
      "type": "string",
      "description": "Canonical diagram type from the exhaustive taxonomy.",
      "enum": [
        "system_context",
        "component_map",
        "feature_map",
        "page_feature_map",
        "system_map",
        "data_flow",
        "execution_sequence",
        "dependency_impact",
        "test_coverage",
        "deployment_impact",
        "state_machine",
        "event_flow",
        "api_surface",
        "schema_map",
        "security_model",
        "threat_model",
        "trust_boundary",
        "auth_flow",
        "network_topology",
        "infrastructure_map",
        "ci_pipeline",
        "release_pipeline",
        "rollback_map",
        "agent_workflow",
        "agent_topology",
        "skill_graph",
        "knowledge_mesh",
        "memory_model",
        "ui_layout",
        "ui_navigation",
        "ui_state",
        "user_journey",
        "kernel_subsystem",
        "syscall_map",
        "memory_layout",
        "process_model",
        "ipc_map",
        "driver_stack",
        "boot_sequence",
        "interrupt_map",
        "capability_model",
        "filesystem_layout",
        "storage_model",
        "replication_model",
        "cache_model",
        "query_plan",
        "wal_flow",
        "compiler_pipeline",
        "ir_graph",
        "codegen_targets",
        "runtime_model",
        "type_system",
        "ownership_model",
        "stdlib_map",
        "cross_repo_dependency",
        "ecosystem_map",
        "proof_matrix_map",
        "traceability_map",
        "drift_map",
        "change_impact",
        "governance_model",
        "cognitive_pipeline",
        "council_topology",
        "authority_flow",
        "acquisition_pipeline",
        "inference_pipeline",
        "verified_boot_chain",
        "emulation_layer",
        "orchestration_map",
        "device_fleet"
      ]
    },
    "layer": {
      "type": "string",
      "description": "Abstraction layer this diagram belongs to.",
      "enum": [
        "architecture",
        "feature",
        "system",
        "security",
        "infrastructure",
        "agent",
        "ui",
        "kernel",
        "storage",
        "compiler",
        "ecosystem",
        "governance"
      ]
    },
    "scope": {
      "type": "string",
      "description": "Granularity of coverage.",
      "enum": ["repo", "subsystem", "page", "component", "cross_repo", "full_system"]
    },
    "applies_to": {
      "type": "array",
      "description": "Repo types this diagram is mandatory or optional for.",
      "items": {
        "type": "string",
        "enum": [
          "any",
          "web_app",
          "api_service",
          "mobile_app",
          "desktop_app",
          "operating_system",
          "sovereign_os",
          "compiler",
          "database",
          "ml_model",
          "cli_tool",
          "library",
          "dashboard",
          "agent_system"
        ]
      }
    },
    "mandatory": {
      "type": "boolean",
      "description": "If true, T1 must produce this diagram for all repos matching applies_to. If false, produced on-demand or by specific slice."
    },
    "source_path":     { "type": "string" },
    "rendered_paths":  { "type": "array", "items": { "type": "string" } },
    "status": {
      "type": "string",
      "enum": ["current", "stale", "missing", "stub"]
    },
    "generated_by":  { "type": "string" },
    "last_updated":  { "type": "string", "format": "date" }
  },
  "required": ["id", "kind", "layer", "scope", "applies_to", "mandatory", "source_path"],
  "additionalProperties": false
}
