{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidencePacket",
  "description": "Validates an evidence packet that captures artifacts and test results for a vertical slice.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "date", "artifact_links", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^EP-\\d{4}-\\d{2}-\\d{2}-",
      "description": "Unique identifier in the form EP-YYYY-MM-DD-<slug>"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "artifact_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path"],
        "properties": {
          "type": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "complete"]
    },
    "slice_id": {
      "type": "string"
    },
    "test_results": {
      "type": "object",
      "additionalProperties": true
    },
    "preview_url": {
      "type": "string",
      "format": "uri"
    }
  }
}
