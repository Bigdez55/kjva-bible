{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntakePacket",
  "description": "Validates an intake packet capturing raw ideas before they are promoted into vertical slices.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "raw_idea", "value_statement", "date", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^IDEA-\\d{4}-",
      "description": "Unique identifier in the form IDEA-NNNN-<slug>"
    },
    "raw_idea": {
      "type": "string",
      "minLength": 10
    },
    "value_statement": {
      "type": "string",
      "minLength": 5
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": ["raw", "validated", "promoted", "rejected"]
    }
  }
}
