{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill",
  "description": "Validates a skill definition document in the Development_Skills knowledge base.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "version",
    "layer",
    "domains",
    "playbook",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^SKILL_[A-Z0-9_]+_\\d{3}$",
      "description": "Unique skill identifier in the form SKILL_<DOMAIN>_NNN"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "layer": {
      "type": "string",
      "description": "Architectural layer this skill operates in (e.g. core, application, integration)"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "playbook": {
      "type": "string",
      "description": "Relative path to the associated command playbook file"
    },
    "validation_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "improvement_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "experimental"
      ]
    },
    "skill_number": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        }
      ]
    },
    "source_documents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trigger_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hard_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tier": {
      "type": "string",
      "enum": [
        "starter",
        "active",
        "refining",
        "hardened",
        "apex",
        "one-shot-apex"
      ]
    },
    "ledger": {
      "type": "string"
    },
    "related_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "router_intents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Alternate names (kebab-case preferred) used by runtime projections. First alias is the preferred kebab name."
    },
    "source": {
      "type": "string",
      "enum": [
        "native",
        "migrated_user",
        "promoted_external"
      ],
      "description": "Provenance of this skill. native=born here (skill_number 1-499); migrated_user=migrated from ~/.claude/skills/ (500-999); promoted_external=promoted from .claude/.codex/.gemini import (1000-1999)."
    },
    "runtime_projection": {
      "type": "boolean",
      "description": "Master switch: whether ANY runtime shim is generated for this skill. Default true."
    },
    "runtime_projection_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "claude",
          "codex",
          "gemini"
        ]
      },
      "uniqueItems": true,
      "description": "Per-runtime selection. Default = [claude, codex, gemini] (all)."
    },
    "refinement": {
      "type": "string",
      "enum": [
        "auto",
        "frozen"
      ],
      "description": "Whether the auto-refinement engine (Phase 8) is permitted to refine this skill. Default auto. Set to frozen for skills whose correctness is provable rather than empirical (e.g., bootstrap-critical compiler skills)."
    },
    "improvement_metrics": {
      "type": "object",
      "description": "Auto-maintained by the refinement engine. Do not hand-edit.",
      "additionalProperties": false,
      "properties": {
        "invocation_count": {
          "type": "integer",
          "minimum": 0
        },
        "correction_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_correction": {
          "type": ["string", "null"]
        },
        "corrections_per_100_uses": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "last_refinement": {
          "type": ["string", "null"]
        },
        "refinement_count": {
          "type": "integer",
          "minimum": 0
        },
        "tier_promotion_history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "use_telemetry": {
      "type": "array",
      "description": "Ring buffer of last N invocations (bounded; default N=100). Auto-maintained.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "refinement_log": {
      "type": "array",
      "description": "Append-only log of every auto-refinement applied to this skill.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "superseded_by": {
      "type": "string",
      "pattern": "^SKILL_[A-Z0-9_]+_\\d{3}$",
      "description": "If this skill is in superseded/, the canonical ID of its successor."
    },
    "deprecation_reason": {
      "type": "string",
      "description": "If this skill is in deprecated/, the human-readable reason."
    },
    "deprecated_on": {
      "type": "string",
      "description": "ISO date when the skill was deprecated."
    },
    "regression_cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "slash_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "name": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "known_failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mcp_tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "server": {
      "type": "object",
      "additionalProperties": true
    },
    "catalog": {
      "type": "object",
      "additionalProperties": true
    },
    "corrective_contract": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proof_contract": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
