{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SourceImportManifest",
  "type": "object",
  "required": [
    "version",
    "collection",
    "sources"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string"
    },
    "collection": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "supersession_rule": {
      "type": "string"
    },
    "sources": {
      "type": "array"
    }
  }
}
