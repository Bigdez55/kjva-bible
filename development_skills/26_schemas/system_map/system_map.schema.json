{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "system_map",
  "description": "Full cross-page system map for a UI repo",
  "type": "object",
  "properties": {
    "id": {"type": "string"},
    "repo": {"type": "string"},
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "element_count": {"type": "integer"},
          "health_score": {"type": "number", "minimum": 0, "maximum": 100},
          "status": {"type": "string", "enum": ["healthy", "degraded", "broken", "unknown"]}
        },
        "required": ["name", "element_count", "health_score", "status"]
      }
    },
    "overall_health_score": {"type": "number", "minimum": 0, "maximum": 100},
    "last_audited": {"type": "string", "format": "date"}
  },
  "required": ["id", "repo", "pages", "overall_health_score", "last_audited"],
  "additionalProperties": false
}
