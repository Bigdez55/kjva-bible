{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TraceabilityRow",
  "description": "Validates a single row in the traceability matrix linking specs, ADRs, diagrams, tests, and evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_id", "status"],
  "properties": {
    "spec_id": {
      "type": "string"
    },
    "adr_id": {
      "type": "string"
    },
    "diagram_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "test_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_id": {
      "type": "string"
    },
    "deployment_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["complete", "partial", "missing"]
    }
  }
}
