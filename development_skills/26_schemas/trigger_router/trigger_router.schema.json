{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanonicalTriggerRouter",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "model",
    "precedence",
    "behavioral_protocols",
    "root_verbs",
    "noun_branches",
    "modifiers",
    "targets",
    "correctives"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "naming_policy": {
      "type": "string"
    },
    "model": {
      "const": "verb_first_noun_refined"
    },
    "precedence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "behavioral_protocols": {
      "type": "object"
    },
    "root_verbs": {
      "type": "object"
    },
    "noun_branches": {
      "type": "object"
    },
    "modifiers": {
      "type": "object",
      "required": [
        "depth",
        "output",
        "proof",
        "audience"
      ]
    },
    "targets": {
      "type": "object"
    },
    "correctives": {
      "type": "object"
    },
    "compatibility_intents": {
      "type": "object"
    },
    "default_core_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
