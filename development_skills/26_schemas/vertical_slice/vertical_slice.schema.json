{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerticalSlice",
  "description": "Validates a vertical slice definition tracking spec links, proof requirements, and preview deployment.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "spec_links", "proof_requirements", "preview_deploy", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^SLICE-\\d{4}-",
      "description": "Unique identifier in the form SLICE-NNNN-<slug>"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "spec_links": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "proof_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["test_ids", "diagram_ids", "adr_ids"],
      "properties": {
        "test_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "diagram_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "adr_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "preview_deploy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "build_steps", "rollback_path"],
      "properties": {
        "target": {
          "type": "string"
        },
        "build_steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rollback_path": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "complete", "abandoned"]
    }
  }
}
